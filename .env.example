# ─── QueryIQ — Environment Variables Template ─────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file to version control.
#
# Generate secrets with:
#   JWT_SECRET:       python -c "import secrets; print(secrets.token_hex(64))"
#   JWT_REFRESH_SECRET: python -c "import secrets; print(secrets.token_hex(64))"
#   FERNET_KEY:       python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ─────────────────────────────────────────────────────────────────────────────

# ─── Environment ──────────────────────────────────────────────────────────────
# Options: "development" | "production"
ENVIRONMENT=development

# ─── Server ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
APP_VERSION=2.0.0

# Production: Set to your actual domain
# FRONTEND_URL=https://your-domain.com
# ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# ─── Security (REQUIRED in production) ───────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_secrets_token_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_secrets_token_hex_64
FERNET_KEY=CHANGE_ME_generate_with_Fernet_generate_key

# ─── Database ─────────────────────────────────────────────────────────────────
# Development: SQLite (default)
DATABASE_URL=sqlite:///studio_metadata.db

# Production: PostgreSQL (recommended)
# DATABASE_URL=postgresql://user:password@host:5432/queryiq_db
# POSTGRES_POOL_SIZE=10
# POSTGRES_MAX_OVERFLOW=20

# ─── LLM ──────────────────────────────────────────────────────────────────────
LLM_TIMEOUT_SECONDS=35
LLM_MAX_RETRIES=1
DEFAULT_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Gemini API (for cloud LLM support)
# GEMINI_API_KEY=your_gemini_api_key_here

# ─── Engine Routing ───────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD_DETERMINISTIC=0.85
CONFIDENCE_THRESHOLD_HYBRID=0.60

# ─── Cache ────────────────────────────────────────────────────────────────────
QUERY_CACHE_TTL_SECONDS=1800
SCHEMA_CACHE_TTL_SECONDS=3600
QUERY_CACHE_MAX_ENTRIES=500
CONVERSATION_CACHE_TTL_SECONDS=900
KPI_CACHE_TTL_SECONDS=1800

# ─── Sandbox Execution ────────────────────────────────────────────────────────
SANDBOX_TIMEOUT_SECONDS=25
MAX_RESULT_ROWS=10000
PREVIEW_ROWS=15
